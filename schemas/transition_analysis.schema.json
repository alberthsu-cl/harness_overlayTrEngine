{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OverlayTransitionAnalysis",
  "type": "object",
  "properties": {
    "artifact_type": {
      "const": "transition_analysis"
    },
    "artifact_version": {
      "type": "integer",
      "minimum": 2
    },
    "sources": {
      "type": "object",
      "properties": {
        "source_a": {
          "type": "string"
        },
        "source_b": {
          "type": "string"
        },
        "reference_transition": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "source_a",
        "source_b"
      ]
    },
    "facts": {
      "type": "object",
      "properties": {
        "analyzer_inputs": {
          "type": "object"
        },
        "resolved": {
          "type": "object"
        },
        "signals": {
          "type": "object"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "analyzer_inputs",
        "resolved",
        "signals"
      ]
    },
    "planning_recommendation": {
      "type": "object",
      "properties": {
        "producer": {
          "type": "string"
        },
        "auto": {
          "type": "boolean"
        },
        "style": {
          "type": "string"
        },
        "input_kind": {
          "type": "string"
        },
        "preset": {
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "type": "string"
        },
        "job_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "hint": {
          "type": "object"
        }
      },
      "required": [
        "producer",
        "auto",
        "style",
        "input_kind",
        "mode",
        "hint"
      ]
    }
  },
  "required": [
    "artifact_type",
    "artifact_version",
    "sources",
    "facts",
    "planning_recommendation"
  ],
  "additionalProperties": true
}